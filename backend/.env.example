# ===== ToyLab Backend 环境变量 =====

# Demo 阶段使用 SQLite（零配置），正式环境切换 PostgreSQL
DATABASE_URL=sqlite+aiosqlite:///./toylab.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/toylab

# JWT 密钥（生产环境请更换为随机长字符串）
SECRET_KEY=toylab-dev-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 文件上传目录（Demo 阶段存本地）
UPLOAD_DIR=./uploads
